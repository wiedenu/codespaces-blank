[
  {
    "name": "header",
    "label": "Header",
    "type": "text",
    "default": "What We Finance",
    "required": false
  },
  {
    "name": "content",
    "label": "Content / Subheader",
    "type": "richtext",
    "default": "<p>From office equipment to IT infrastructure, we provide flexible financing across the technologies your business depends on.</p>",
    "required": false
  },
  {
    "name": "style_variant",
    "label": "Card Color Style",
    "type": "choice",
    "display": "select",
    "default": "blue",
    "required": true,
    "choices": [
      ["blue", "Blue header / Gold accent"],
      ["gold", "Gold header / Blue accent"]
    ]
  },
  {
    "name": "number_of_columns_desktop",
    "label": "Number of Columns (Desktop)",
    "type": "choice",
    "display": "select",
    "default": "one-third",
    "required": true,
    "choices": [
      ["one-half", "2"],
      ["one-third", "3"],
      ["one-fourth", "4"]
    ]
  },
  {
    "name": "number_of_columns_tablet",
    "label": "Number of Columns (Tablet)",
    "type": "choice",
    "display": "select",
    "default": "tablet-one-half",
    "required": true,
    "choices": [
      ["tablet-one-whole", "1"],
      ["tablet-one-half", "2"]
    ]
  },
  {
    "name": "number_of_columns_mobile",
    "label": "Number of Columns (Mobile)",
    "type": "choice",
    "display": "select",
    "default": "palm-one-whole",
    "required": true,
    "choices": [
      ["palm-one-whole", "1"],
      ["palm-one-half", "2"]
    ]
  },
  {
    "name": "column_content",
    "label": "Column Content",
    "type": "group",
    "occurrence": {
      "default": 6,
      "sorting_label_field": "header_label"
    },
    "required": false,
    "children": [
      {
        "name": "icon_or_image",
        "label": "Icon or Image",
        "type": "choice",
        "display": "select",
        "default": "icon",
        "required": true,
        "choices": [
          ["icon", "FontAwesome Icon"],
          ["image", "Image"]
        ]
      },
      {
        "name": "fontawesome_icon_code",
        "label": "FontAwesome Icon Code",
        "type": "text",
        "default": "<i class=\"fas fa-building\" aria-hidden=\"true\"></i>",
        "required": true,
        "visibility": {
          "controlling_field": "icon_or_image",
          "controlling_value_regex": "icon",
          "operator": "EQUAL"
        }
      },
      {
        "name": "image_icon",
        "label": "Image",
        "type": "image",
        "required": true,
        "resizable": true,
        "visibility": {
          "controlling_field": "icon_or_image",
          "controlling_value_regex": "image",
          "operator": "EQUAL"
        }
      },
      {
        "name": "header_label",
        "label": "Category Title",
        "type": "text",
        "default": "Office Equipment",
        "required": true
      },
      {
        "name": "description",
        "label": "Item List (rich text — use a bullet list)",
        "type": "richtext",
        "default": "<ul><li>Printers, copiers, scanners</li><li>Mailing equipment</li><li>Paper shredders</li></ul>",
        "required": false
      }
    ],
    "default": [
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-building\" aria-hidden=\"true\"></i>",
        "header_label": "Office Equipment",
        "description": "<ul><li>Printers, copiers, scanners</li><li>Mailing equipment</li><li>Paper shredders</li><li>Water coolers</li><li>Managed print services</li></ul>"
      },
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-server\" aria-hidden=\"true\"></i>",
        "header_label": "IT Hardware &amp; Infrastructure",
        "description": "<ul><li>PCs and laptops</li><li>Servers &amp; dedicated private-cloud servers</li><li>SANs &amp; backup devices</li><li>Network hardware (routers, switches, firewalls)</li><li>Wi-Fi, access points, wireless controllers</li><li>SD-WAN</li><li>IT infrastructure projects</li></ul>"
      },
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-headset\" aria-hidden=\"true\"></i>",
        "header_label": "Communications &amp; Collaboration",
        "description": "<ul><li>VoIP, UC, telephony</li><li>IP phones</li><li>Conferencing &amp; video devices</li><li>Contact center solutions</li></ul>"
      },
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-window\" aria-hidden=\"true\"></i>",
        "header_label": "Software &amp; Licensing",
        "description": "<ul><li>Business software</li><li>Software licensing</li><li>Cloud software projects</li></ul>"
      },
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-display\" aria-hidden=\"true\"></i>",
        "header_label": "Audio-Visual &amp; Digital Experience",
        "description": "<ul><li>Digital signage</li><li>Displays, projection, sound</li><li>Audio-visual systems</li></ul>"
      },
      {
        "icon_or_image": "icon",
        "fontawesome_icon_code": "<i class=\"fas fa-shield-check\" aria-hidden=\"true\"></i>",
        "header_label": "Security &amp; Surveillance",
        "description": "<ul><li>Physical security &amp; surveillance</li><li>Security equipment</li></ul>"
      }
    ]
  },
  {
    "name": "background_type",
    "label": "Background: Type",
    "type": "choice",
    "display": "select",
    "default": "color",
    "required": true,
    "choices": [
      ["image", "Image"],
      ["color", "Color"],
      ["gradient", "Gradient"]
    ]
  },
  {
    "name": "background_overlay_type",
    "label": "Background: Overlay Type",
    "type": "choice",
    "display": "select",
    "default": "none",
    "required": true,
    "choices": [
      ["none", "No Overlay"],
      ["image", "Image"],
      ["color", "Color"],
      ["gradient", "Gradient"]
    ]
  },
